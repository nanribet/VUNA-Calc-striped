{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest"
  },
  "ignorePatterns": ["calculator/assets/js/bootstrap.min.js"],
  "rules": {
    "no-unused-vars": ["warn", { "vars": "local", "args": "none" }],
    "no-undef": "error",
    "semi": ["warn", "always"],
    "quotes": ["warn", "double"],
    "no-console": "off"
  }
}
